<Window x:Class="Eureka.LargeFileWarning"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Eureka" Width="450" Height="240"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Background="{DynamicResource BackgroundBrush}">
    
    <StackPanel Margin="28">
        <TextBlock Text="Large File" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,16"/>
        
        <TextBlock x:Name="MessageText"
                   TextWrapping="Wrap" FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   LineHeight="22" Margin="0,0,0,24"/>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="OnCancel"
                    Padding="24,10" FontSize="13"
                    Background="{DynamicResource SurfaceBrush}" 
                    Foreground="{DynamicResource TextBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Cursor="Hand"/>
            <Button Content="Open" Click="OnOpen"
                    Padding="24,10" FontSize="13" FontWeight="SemiBold"
                    Background="{DynamicResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="10,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>
