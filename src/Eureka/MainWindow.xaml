<Window x:Class="Eureka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Eureka.Controls"
        Title="Eureka"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        AllowDrop="True"
        Drop="OnDrop"
        DragOver="OnDragOver">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Image Canvas -->
        <controls:ImageCanvas x:Name="Canvas" Grid.Row="0"
                              ZoomChanged="OnZoomChanged"
                              PixelHovered="OnPixelHovered"
                              AllowDrop="True"
                              Drop="OnDrop"
                              DragOver="OnDragOver"/>
        
        <!-- Drop hint -->
        <StackPanel x:Name="DropHint" Grid.Row="0" 
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsHitTestVisible="False">
            <TextBlock Text="Drop image here or click Open" 
                       Foreground="{DynamicResource TextTertiaryBrush}" 
                       FontSize="24" HorizontalAlignment="Center"/>
        </StackPanel>
        
        <!-- Bottom Control Bar -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" 
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- File Info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="FileInfoText" Text="No image loaded" 
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                </StackPanel>
                
                <!-- Zoom Controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" 
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="ZoomText" Text="100%" 
                               Foreground="{DynamicResource TextBrush}" FontSize="12" 
                               MinWidth="50" TextAlignment="Center" VerticalAlignment="Center"/>
                    
                    <Border Width="1" Height="20" Background="{DynamicResource BorderBrush}" Margin="8,0"/>
                    
                    <Button Content="Fit" Style="{StaticResource ToolButton}" 
                            Click="OnFitToWindow" Padding="10,4"/>
                    <Button Content="1:1" Style="{StaticResource ToolButton}" 
                            Click="OnOriginalSize" Padding="10,4"/>
                </StackPanel>
                
                <!-- Tools -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Rotate L" Style="{StaticResource ToolButton}" 
                            Click="OnRotateLeft" Padding="8,4" FontSize="11"/>
                    <Button Content="Rotate R" Style="{StaticResource ToolButton}" 
                            Click="OnRotateRight" Padding="8,4" FontSize="11"/>
                    
                    <Border Width="1" Height="20" Background="{DynamicResource BorderBrush}" Margin="4,0"/>
                    
                    <!-- HDR/SDR indicator -->
                    <TextBlock x:Name="SdrLabel" Text="SDR" 
                               Foreground="{DynamicResource TextTertiaryBrush}" 
                               FontSize="11" VerticalAlignment="Center" Padding="10,4"
                               Visibility="Visible"/>
                    <ToggleButton x:Name="HdrToggle" Content="HDR" 
                                  Style="{StaticResource ToggleButton}" 
                                  Click="OnHdrToggle" Padding="10,4" FontSize="11"
                                  Visibility="Collapsed"/>
                    
                    <Border Width="1" Height="20" Background="{DynamicResource BorderBrush}" Margin="4,0"/>
                    
                    <Button Content="Open" Style="{StaticResource ToolButton}" 
                            Click="OnOpenFile" Padding="10,4" FontWeight="SemiBold"/>
                    
                    <Button Content="Info" Style="{StaticResource ToolButton}" 
                            Click="OnToggleInfo" Padding="10,4"/>
                </StackPanel>
                
                <!-- Color Info -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <Border x:Name="ColorSwatch" Width="18" Height="18" 
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                            Margin="0,0,8,0"/>
                    <TextBlock x:Name="ColorText" Text="" 
                               Foreground="{DynamicResource TextSecondaryBrush}" 
                               FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Info Panel -->
        <Border x:Name="InfoPanel" Grid.Row="0" Grid.RowSpan="2" 
                Width="300" HorizontalAlignment="Right"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource SurfaceAltBrush}" Padding="16,0">
                    <Grid>
                        <TextBlock Text="Image Information" 
                                   Foreground="{DynamicResource TextBrush}" 
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Button Content="X" Style="{StaticResource ToolButton}" 
                                Click="OnToggleInfo" HorizontalAlignment="Right" 
                                Padding="8,4"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
                    <StackPanel x:Name="InfoContent"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
