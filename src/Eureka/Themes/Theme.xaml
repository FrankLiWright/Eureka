<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Color Palette -->
    <!-- Dark Theme -->
    <Color x:Key="DarkBackground">#FF1E1E1E</Color>
    <Color x:Key="DarkSurface">#FF2D2D2D</Color>
    <Color x:Key="DarkSurfaceAlt">#FF3C3C3C</Color>
    <Color x:Key="DarkBorder">#FF404040</Color>
    <Color x:Key="DarkText">#FFFFFFFF</Color>
    <Color x:Key="DarkTextSecondary">#FFB0B0B0</Color>
    <Color x:Key="DarkTextTertiary">#FF808080</Color>
    <Color x:Key="DarkAccent">#FF4FC3F7</Color>
    <Color x:Key="DarkAccentHover">#FF81D4FA</Color>
    
    <!-- Light Theme -->
    <Color x:Key="LightBackground">#FFF5F5F5</Color>
    <Color x:Key="LightSurface">#FFFFFFFF</Color>
    <Color x:Key="LightSurfaceAlt">#FFE8E8E8</Color>
    <Color x:Key="LightBorder">#FFD0D0D0</Color>
    <Color x:Key="LightText">#FF1E1E1E</Color>
    <Color x:Key="LightTextSecondary">#FF606060</Color>
    <Color x:Key="LightTextTertiary">#FF909090</Color>
    <Color x:Key="LightAccent">#FF0288D1</Color>
    <Color x:Key="LightAccentHover">#FF0277BD</Color>
    
    <!-- Active Theme (Default: Dark) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource DarkBackground}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource DarkSurface}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource DarkSurfaceAlt}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource DarkBorder}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource DarkText}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource DarkTextSecondary}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource DarkTextTertiary}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource DarkAccent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource DarkAccentHover}"/>
    
    <!-- Button Style -->
    <Style x:Key="ToolButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="MinWidth" Value="32"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}" 
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource BorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Toggle Button Style -->
    <Style x:Key="ToggleButton" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bg" Background="{TemplateBinding Background}" 
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Slider Style -->
    <Style x:Key="ModernSlider" TargetType="Slider">
        <Setter Property="Height" Value="20"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center">
                        <Border Height="4" CornerRadius="2" Background="{DynamicResource SurfaceAltBrush}"/>
                        <Border Height="4" CornerRadius="2" HorizontalAlignment="Left" 
                                Background="{DynamicResource AccentBrush}">
                            <Border.Width>
                                <MultiBinding>
                                    <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value"/>
                                    <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Maximum"/>
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                        <Thumb x:Name="Thumb" Width="14" Height="14" Background="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
